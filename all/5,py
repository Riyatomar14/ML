import numpy as np
import pandas as pd
import matplotlib.pyplot as plt
import seaborn as sns
from sklearn.datasets import fetch_california_housing
from sklearn.linear_model import LinearRegression, Ridge, Lasso
from sklearn.model_selection import train_test_split, cross_val_score, GridSearchCV
from sklearn.metrics import mean_squared_error, r2_score, mean_absolute_error
from sklearn.preprocessing import StandardScaler

# 1. Load dataset
data = fetch_california_housing()
df = pd.DataFrame(data.data, columns=data.feature_names)
df['Price'] = data.target

print("Shape:", df.shape)
print(df.head())

# 2. Features and target
X = df.drop('Price', axis=1).values
y = df['Price'].values

# 3. Feature Scaling (very important for Ridge and Lasso)
scaler = StandardScaler()
X_scaled = scaler.fit_transform(X)

# 4. Split data
X_train, X_test, y_train, y_test = train_test_split(
    X_scaled, y, test_size=0.2, random_state=42)

# 5. Train all three models
models = {
    'Linear Regression': LinearRegression(),
    'Ridge (alpha=1.0)' : Ridge(alpha=1.0),
    'Lasso (alpha=0.1)' : Lasso(alpha=0.1)
}

results = []
for name, model in models.items():
    model.fit(X_train, y_train)
    y_pred = model.predict(X_test)

    mse  = mean_squared_error(y_test, y_pred)
    rmse = np.sqrt(mse)
    mae  = mean_absolute_error(y_test, y_pred)
    r2   = r2_score(y_test, y_pred)

    results.append({
        'Model': name,
        'MSE'  : round(mse, 4),
        'RMSE' : round(rmse, 4),
        'MAE'  : round(mae, 4),
        'R²'   : round(r2, 4)
    })

    print(f"\n--- {name} ---")
    print("MSE  :", round(mse, 4))
    print("RMSE :", round(rmse, 4))
    print("MAE  :", round(mae, 4))
    print("R²   :", round(r2, 4))

# 6. Comparison table
results_df = pd.DataFrame(results)
print("\n--- Model Comparison ---")
print(results_df.to_string(index=False))

# 7. Coefficient Comparison Plot
coef_df = pd.DataFrame({
    'Feature'           : data.feature_names,
    'Linear Regression' : LinearRegression().fit(X_train, y_train).coef_,
    'Ridge'             : Ridge(alpha=1.0).fit(X_train, y_train).coef_,
    'Lasso'             : Lasso(alpha=0.1).fit(X_train, y_train).coef_
})

print("\n--- Coefficient Comparison ---")
print(coef_df.to_string(index=False))

# Plot coefficients
coef_melted = coef_df.melt(id_vars='Feature',
                            var_name='Model',
                            value_name='Coefficient')

plt.figure(figsize=(10, 5))
sns.barplot(data=coef_melted, x='Feature',
            y='Coefficient', hue='Model')
plt.title("Coefficient Comparison - Linear vs Ridge vs Lasso")
plt.xticks(rotation=45)
plt.tight_layout()
plt.savefig("coefficient_comparison.png")
plt.show()

# 8. Effect of alpha on Ridge coefficients
alphas = [0.001, 0.01, 0.1, 1, 10, 100, 1000]
ridge_coefs = []

for alpha in alphas:
    ridge = Ridge(alpha=alpha)
    ridge.fit(X_train, y_train)
    ridge_coefs.append(ridge.coef_)

plt.figure(figsize=(9, 5))
for i, name in enumerate(data.feature_names):
    plt.plot(alphas, [c[i] for c in ridge_coefs], label=name)
plt.xscale('log')
plt.xlabel("Alpha (log scale)")
plt.ylabel("Coefficient Value")
plt.title("Ridge: Effect of Alpha on Coefficients")
plt.legend(fontsize=8, loc='upper right')
plt.tight_layout()
plt.savefig("ridge_alpha_effect.png")
plt.show()

# 9. Effect of alpha on Lasso coefficients
lasso_coefs = []
alphas_lasso = [0.0001, 0.001, 0.01, 0.1, 0.5, 1.0]

for alpha in alphas_lasso:
    lasso = Lasso(alpha=alpha)
    lasso.fit(X_train, y_train)
    lasso_coefs.append(lasso.coef_)

plt.figure(figsize=(9, 5))
for i, name in enumerate(data.feature_names):
    plt.plot(alphas_lasso,
             [c[i] for c in lasso_coefs], label=name)
plt.xscale('log')
plt.xlabel("Alpha (log scale)")
plt.ylabel("Coefficient Value")
plt.title("Lasso: Effect of Alpha on Coefficients (Feature Selection)")
plt.legend(fontsize=8, loc='upper right')
plt.tight_layout()
plt.savefig("lasso_alpha_effect.png")
plt.show()

# 10. Best alpha using GridSearchCV - Ridge
ridge_params = {'alpha': [0.01, 0.1, 1, 10, 100]}
ridge_cv = GridSearchCV(Ridge(), ridge_params,
                         cv=5, scoring='r2')
ridge_cv.fit(X_train, y_train)
print("\nBest alpha for Ridge:", ridge_cv.best_params_)
print("Best Ridge R²:", round(ridge_cv.best_score_, 4))

# 11. Best alpha using GridSearchCV - Lasso
lasso_params = {'alpha': [0.001, 0.01, 0.1, 0.5, 1.0]}
lasso_cv = GridSearchCV(Lasso(), lasso_params,
                         cv=5, scoring='r2')
lasso_cv.fit(X_train, y_train)
print("\nBest alpha for Lasso:", lasso_cv.best_params_)
print("Best Lasso R²:", round(lasso_cv.best_score_, 4))

# 12. Lasso Feature Selection - which features become zero
best_lasso = Lasso(alpha=lasso_cv.best_params_['alpha'])
best_lasso.fit(X_train, y_train)

print("\n--- Lasso Feature Selection ---")
for name, coef in zip(data.feature_names, best_lasso.coef_):
    status = "ELIMINATED" if coef == 0 else "KEPT"
    print(f"  {name:15s}: {round(coef, 4):8.4f}  [{status}]")

# 13. Cross Validation - best models
for name, model in [('Ridge', Ridge(alpha=ridge_cv.best_params_['alpha'])),
                     ('Lasso', Lasso(alpha=lasso_cv.best_params_['alpha']))]:
    cv = cross_val_score(model, X_scaled, y, cv=10, scoring='r2')
    print(f"\n10-Fold CV R² ({name}):", cv.round(3))
    print(f"Mean R²: {round(cv.mean(), 4)} | Std: {round(cv.std(), 4)}")